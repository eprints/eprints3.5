pipeline{
    agent any
    //  environment {
    //     ARCHIVE_CREDS     = credentials('playwright_db_user')
    // }
    stages{
        stage('Configure EPrints'){
            agent {
                node {
                    label 'eprints_35_deploy'
                    customWorkspace '/opt/eprints3/'
                }
            }
            steps{
                
                customWorkspace '/opt/eprints3/'
                sh "pwd"
                withCredentials([file(credentialsId: 'playwright_archive_config', variable: 'secretFile')]) {
                    sh 'ci/bin/create_eprints_archive playwright $secretFile'
                }
            
                
            }
        }
        stage('Run Tests'){
            steps{
                node('playwright'){
                    withCredentials([file(credentialsId: 'playwright_credentials', variable: 'secretFile')]) {
                        dir("ci/pytest"){
                            sh 'source /home/eprints/pytest-venv/bin/activate && python -m pytest --creds $secretFile --url https://playwright.eprints-hosting.org/'
                        }
                    }
                }
            }
        }
    }
}